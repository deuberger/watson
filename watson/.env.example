# Atlassian Rovo MCP Server
# Generate a scoped API token at:
# https://support.atlassian.com/atlassian-rovo-mcp-server/docs/configuring-authentication-via-api-token/
ATLASSIAN_API_TOKEN=your_rovo_mcp_scoped_api_token

# Default Jira project key (used with --component / --priority filters)
JIRA_PROJECT=PROJ

# GitHub Copilot (used as LLM)
# Use a GitHub PAT with copilot scope, or: export GITHUB_TOKEN=$(gh auth token)
GITHUB_TOKEN=your_github_token

# Optional tuning
WATSON_LLM_MODEL=gpt-4o
WATSON_MAX_AGENT_TURNS=20
WATSON_OUTPUT_DIR=./output
WATSON_MCP_CONFIG=./mcp_servers.json
